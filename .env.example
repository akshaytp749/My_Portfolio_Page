# The agent backend works with ANY OpenAI-compatible provider. Pick one free tier:
#
# Groq (default)  key: https://console.groq.com/keys
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_MODEL=llama-3.3-70b-versatile
#
# OpenRouter      key: https://openrouter.ai/keys
#   LLM_BASE_URL=https://openrouter.ai/api/v1
#   LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
#
# Google Gemini   key: https://aistudio.google.com/apikey
#   LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   LLM_MODEL=gemini-2.5-flash-lite

LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Production hardening (all optional; skipped when unset — fine for local dev)
# Comma-separated origins allowed to call /api/chat, e.g. https://akshaythomas.dev
ALLOWED_ORIGINS=
# Upstash Redis (free tier) for per-IP rate limiting + notification throttling:
# https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Activity notifications (optional): email when someone asks the agent / downloads
# the resume / clicks email. Primary = email via Resend (free): https://resend.com
#   RESEND_API_KEY=re_...            (create at resend.com/api-keys)
#   NOTIFY_EMAIL_TO=you@gmail.com    (in Resend test mode this must be your Resend
#                                     signup email; verify a domain to send elsewhere)
#   NOTIFY_EMAIL_FROM=Portfolio <onboarding@resend.dev>   (default; override w/ your domain)
RESEND_API_KEY=
NOTIFY_EMAIL_TO=
NOTIFY_EMAIL_FROM=
# Or swap email for a webhook (set ONE instead of the Resend vars):
#   DISCORD_WEBHOOK_URL=   SLACK_WEBHOOK_URL=   TELEGRAM_BOT_TOKEN= + TELEGRAM_CHAT_ID=
