# The agent backend works with ANY OpenAI-compatible provider. Pick one free tier:
#
# Groq (default)  key: https://console.groq.com/keys
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_MODEL=llama-3.3-70b-versatile
#
# OpenRouter      key: https://openrouter.ai/keys
#   LLM_BASE_URL=https://openrouter.ai/api/v1
#   LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
#
# Google Gemini   key: https://aistudio.google.com/apikey
#   LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   LLM_MODEL=gemini-2.5-flash-lite

LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Production hardening (all optional; skipped when unset — fine for local dev)
# Comma-separated origins allowed to call /api/chat, e.g. https://akshaythomas.dev
ALLOWED_ORIGINS=
# Upstash Redis (free tier) for per-IP rate limiting: https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
